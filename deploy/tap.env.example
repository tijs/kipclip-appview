# TAP environment config example.
# Real config lives at /etc/tap/env on the box — keep secrets out of the repo.
# TAP uses env vars exclusively (not YAML). Full reference:
# https://github.com/bluesky-social/indigo/blob/main/cmd/tap/README.md

# --- Core ---
TAP_BIND=127.0.0.1:2480
TAP_DATABASE_URL=sqlite:///var/lib/tap/tap.db
TAP_RELAY_URL=https://relay1.us-east.bsky.network
TAP_PLC_URL=https://plc.directory
TAP_LOG_LEVEL=info

# --- Delivery: webhook mode ---
TAP_WEBHOOK_URL=http://127.0.0.1:8000/api/sync/hook
# NOTE: TAP reuses TAP_ADMIN_PASSWORD as outbound webhook auth, sent as
# `Authorization: Basic admin:<password>` on every delivery. Set
# TAP_WEBHOOK_SECRET to the SAME value in /etc/kipclip/env so the
# webhook receiver (worker/webhook.ts) can validate inbound requests.
# Generate: openssl rand -hex 32
TAP_ADMIN_PASSWORD=

# --- Collection filters ---
# All 5 collections the webhook handler (worker/webhook.ts) processes.
TAP_COLLECTION_FILTERS=community.lexicon.bookmarks.bookmark,app.bookmark.annotation,com.kipclip.annotation,com.kipclip.tag,com.kipclip.preferences

# --- Parallelism / performance ---
# Defaults are sensible for kipclip's scale. Tune if needed.
# TAP_FIREHOSE_PARALLELISM=10
# TAP_RESYNC_PARALLELISM=5
# TAP_OUTBOX_PARALLELISM=1

# --- Observability ---
# Expose Prometheus metrics + pprof on a local-only port.
# TAP_METRICS_LISTEN=127.0.0.1:2481

# --- Timeouts ---
# TAP_REPO_FETCH_TIMEOUT=300s
# TAP_RETRY_TIMEOUT=60s
# TAP_CURSOR_SAVE_INTERVAL=1s
