# kipclip server environment.
#
# Real file lives at /etc/kipclip/env on the production box (mode 0640,
# owner root:kipclip). Loaded by kipclip.service via EnvironmentFile=.
# NEVER commit the real file. This example is the contract — copy it,
# fill in secrets locally, deploy via your own out-of-band channel
# (ssh + scp, sops, etc).
#
# Generate secrets:
#   COOKIE_SECRET:   openssl rand -hex 32
#   TAP_WEBHOOK_SECRET: openssl rand -hex 32 (must match TAP_ADMIN_PASSWORD
#                       in /etc/tap/env — TAP reuses admin auth for
#                       outbound webhook auth)

# === Required ===

# 32+ random bytes hex. Used by oauth-storage to sign session cookies.
# Rotating invalidates all sessions.
COOKIE_SECRET=

# Public URL the AppView is served from. OAuth uses this to derive
# client_id + redirect_uris. Pin to the canonical hostname so OAuth client
# metadata stays stable across requests.
BASE_URL=https://kipclip.com

# === Optional but recommended ===

# Sentry DSN for error reporting. SENTRY_RELEASE is set per-deploy by
# update.sh via systemd drop-in (don't set it here).
SENTRY_DSN=

# === Box-only (mirror) ===

# Primary SQLite database path. All tables live here: OAuth sessions,
# user_settings, import_jobs, and all mirror tables.
DATABASE_URL=file:/var/lib/kipclip/kipclip.db

# read = serve mirror-aware reads from local SQLite for tracked DIDs.
# off  = always read from PDS (default if unset).
MIRROR_MODE=read

# Async webhook ack — TAP webhook handler returns 200 immediately and
# processes in background. on = ack-async, off = ack-after-write.
MIRROR_WEBHOOK_ACK_ASYNC=on

# Shared secret with TAP. Must equal TAP_ADMIN_PASSWORD in /etc/tap/env.
# kipclip's /api/sync/hook validates `Authorization: Basic admin:<pw>`.
TAP_WEBHOOK_SECRET=
