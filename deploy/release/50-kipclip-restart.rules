// Allow the kipclip user to manage the kipclip + kipclip-release units
// (start/restart/reload) AND to call `systemctl daemon-reload` without
// sudo. Both are required by deploy/release/update.sh, which runs as
// the kipclip user under the kipclip-release.timer.
//
// `manage-units`     — covers systemctl restart kipclip
// `reload-daemon`    — covers systemctl daemon-reload after writing the
//                      SENTRY_RELEASE drop-in. daemon-reload is a
//                      machine-wide action, not unit-scoped, so we
//                      grant it to the kipclip user globally rather
//                      than per-unit.
//
// Installed to /etc/polkit-1/rules.d/50-kipclip-restart.rules by
// deploy/release/bootstrap.sh.
polkit.addRule(function(action, subject) {
    if (subject.user != "kipclip") return polkit.Result.NOT_HANDLED;

    if (action.id == "org.freedesktop.systemd1.manage-units") {
        var unit = action.lookup("unit");
        if (unit == "kipclip.service" ||
            unit == "kipclip-release.service" ||
            unit == "kipclip-release.timer") {
            return polkit.Result.YES;
        }
    }

    if (action.id == "org.freedesktop.systemd1.reload-daemon") {
        return polkit.Result.YES;
    }

    return polkit.Result.NOT_HANDLED;
});
