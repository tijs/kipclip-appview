# TAP config example. Real config lives at /etc/tap/config.yaml on the box —
# keep secrets out of the repo. Final schema TBD against the chosen TAP version
# (see U10 in docs/plans/2026-05-02-001-feat-appview-mirror-phases-0-2-plan.md).

upstream:
  relay: "wss://bsky.network"

filter:
  collections:
    - "community.lexicon.bookmarks.bookmark"
    - "app.bookmark.annotation"
    - "com.kipclip.tag"

webhook:
  url: "http://127.0.0.1:8000/api/sync/hook"
  # NOTE: TAP doesn't have a separate webhook auth setting. It REUSES
  # TAP_ADMIN_PASSWORD as both the inbound HTTP API basic-auth password
  # AND the outbound webhook auth (sent as `Authorization: Basic
  # admin:<password>` on every webhook delivery — see
  # cmd/tap/webhook_client.go in bluesky-social/indigo).
  #
  # To enable defense-in-depth on kipclip's webhook receiver:
  #   1. Set TAP_ADMIN_PASSWORD in /etc/tap/env (TAP side).
  #   2. Set TAP_WEBHOOK_SECRET to the SAME value in /etc/kipclip/env
  #      (kipclip side — worker/webhook.ts validates Basic admin:<pw>
  #      AND Bearer <secret> for forward-compat).
  #   3. Restart both services in the same maintenance window.
  #
  # Generate a 32+-char random secret:
  #   openssl rand -hex 32
  #
  # The Caddy `respond @hook 403` matcher in deploy/Caddyfile is the
  # primary barrier; the auth check catches config drift.

control:
  # HTTP control plane for adding/removing tracked DIDs.
  # routes/api/sync.ts → POST http://127.0.0.1:7000/admin/track
  bind: "127.0.0.1:7000"

state_dir: /var/lib/tap

dids: []  # Populated dynamically by /api/sync/track at user signup.
