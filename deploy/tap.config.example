# TAP config example. Real config lives at /etc/tap/config.yaml on the box —
# keep secrets out of the repo. Final schema TBD against the chosen TAP version
# (see U10 in docs/plans/2026-05-02-001-feat-appview-mirror-phases-0-2-plan.md).

upstream:
  relay: "wss://bsky.network"

filter:
  collections:
    - "community.lexicon.bookmarks.bookmark"
    - "app.bookmark.annotation"
    - "com.kipclip.tag"

webhook:
  url: "http://127.0.0.1:8000/api/sync/hook"
  # Defense-in-depth shared secret between TAP and kipclip.
  #
  # When `Authorization: Bearer <secret>` is sent on every webhook AND
  # kipclip's TAP_WEBHOOK_SECRET env var matches, the kipclip-side
  # check in worker/webhook.ts handleWebhookRequest enforces the bearer
  # token before parsing the body. The Caddy `respond @hook 403`
  # matcher in deploy/Caddyfile is the primary barrier; the bearer is
  # what catches config drift.
  #
  # Rollout policy: leave both sides unset until coordinated. When
  # ready, set kipclip's TAP_WEBHOOK_SECRET in /etc/kipclip/env and add
  # the matching value here, then restart both services in the same
  # maintenance window. Generate a 32+-char random secret:
  #   openssl rand -hex 32
  authorization_bearer: ""  # set to match TAP_WEBHOOK_SECRET on kipclip

control:
  # HTTP control plane for adding/removing tracked DIDs.
  # routes/api/sync.ts → POST http://127.0.0.1:7000/admin/track
  bind: "127.0.0.1:7000"

state_dir: /var/lib/tap

dids: []  # Populated dynamically by /api/sync/track at user signup.
