# restic backup environment for /var/lib/kipclip/mirror.db + sessions.
#
# Real file at /etc/kipclip/restic.env on the box (mode 0640, owner
# root:kipclip). Loaded by restic-backup.service. NEVER commit the
# real file.
#
# Backend: Backblaze B2 via S3-compatible API. To rotate credentials,
# create new B2 application key, swap here, restart timer.
#
# Generate restic password:
#   openssl rand -hex 32
# (write it down out-of-band BEFORE first backup — losing it makes the
#  repo unrecoverable)

# Repo URL. s3:<endpoint>/<bucket>. eu-central-003 example below.
RESTIC_REPOSITORY=s3:s3.eu-central-003.backblazeb2.com/kipclip-backups

# 32+-char passphrase encrypting every blob in the repo.
RESTIC_PASSWORD=

# B2 application key (S3 API).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-003
