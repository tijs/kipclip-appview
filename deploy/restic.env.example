# restic backup environment for kipclip primary SQLite + TAP state.
#
# Real file at /etc/kipclip/restic.env on the box (mode 0640, owner
# root:kipclip). Loaded by restic-backup.service. NEVER commit the
# real file.
#
# Backend: Scaleway Object Storage (S3-compatible, fr-par region).
# To rotate credentials, create new Scaleway IAM key, swap here, restart timer.
#
# Generate restic password:
#   openssl rand -hex 32
# (write it down out-of-band BEFORE first backup — losing it makes the
#  repo unrecoverable)

# Repo URL. s3:<endpoint>/<bucket>.
RESTIC_REPOSITORY=s3:s3.fr-par.scw.cloud/kipclip-restic

# 32+-char passphrase encrypting every blob in the repo.
RESTIC_PASSWORD=

# Scaleway IAM application key (S3-compatible API).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
